{
  "name": "wordnest",
  "version": "1.0.12",
  "description": "WordNest – ứng dụng học từ vựng tiếng Anh cá nhân (Flashcard SRS, Quiz, Chính tả, Từ điển).",
  "main": "electron/main.js",
  "author": "ngphatdat1311",
  "private": true,
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dist": "electron-builder",
    "dist:dir": "electron-builder --dir"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4"
  },
  "build": {
    "appId": "com.wordnest.app",
    "productName": "WordNest",
    "files": [
      "index.html",
      "css/**",
      "js/**",
      "assets/**",
      "electron/**",
      "node_modules/**",
      "package.json",
      "!extension/**"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "ngphatdat1311",
        "repo": "WORDNEST"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icons/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "assets/icons/icon-512.png",
      "category": "public.app-category.education"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    }
  }
}
