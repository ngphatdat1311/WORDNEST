{
  "manifest_version": 3,
  "name": "WordNest Capture",
  "version": "1.0.0",
  "description": "Bôi đen một từ tiếng Anh trên bất kỳ trang web nào để gửi vào hộp thư WordNest.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_popup": "popup.html"
  },
  "permissions": ["storage", "contextMenus", "activeTab", "notifications"],
  "host_permissions": ["<all_urls>", "http://127.0.0.1:51789/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": ["file:///*"],
      "js": ["content-capture.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*", "file:///*"],
      "js": ["content-bridge.js"],
      "run_at": "document_idle"
    }
  ]
}
